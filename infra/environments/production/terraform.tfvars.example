

aws_region  = "us-east-1"
project     = "cloudmart"
environment = "production"
team        = "Team-Pixels"
owner_email = "kavisekarais.21@uom.lk"

monthly_budget_usd       = 100
budget_notification_emails = ["kavisekarais.21@uom.lk"]
account_id                  = "123456789012"
rds_kms_key_arn             = "arn:aws:kms:us-east-1:123456789012:key/REPLACE_WITH_EXISTING_RDS_KEY"

# Network – 3 AZs for high availability
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24", "10.0.12.0/24"]
data_subnet_cidrs    = ["10.0.20.0/24", "10.0.21.0/24", "10.0.22.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b", "us-east-1c"]

cluster_public_access_cidrs = ["0.0.0.0/0"] # Restrict to trusted egress CIDRs where possible.
enable_bastion              = true
bastion_allowed_cidrs       = [] # Empty means SSM Session Manager only.


