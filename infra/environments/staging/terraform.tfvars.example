aws_region  = "us-east-1"
project     = "cloudmart"
environment = "staging"
team        = "Team-Pixels"
owner_email = "okdkithmini@gmail.com"

monthly_budget_usd         = 50
budget_notification_emails = ["okdkithmini@gmail.com"]
account_id                  = "123456789012"
oidc_url                    = "oidc.eks.us-east-1.amazonaws.com/id/REPLACE_WITH_CLUSTER_OIDC_ID"
production_vpc_id           = "vpc-REPLACE_FROM_PRODUCTION_OUTPUT"
production_private_route_table_ids = [
  "rtb-REPLACE_FROM_PRODUCTION_OUTPUT"
]
production_eks_security_group_id = "sg-REPLACE_FROM_PRODUCTION_OUTPUT"

# Network
vpc_cidr             = "10.1.0.0/16"
public_subnet_cidrs  = ["10.1.1.0/24", "10.1.2.0/24"]
private_subnet_cidrs = ["10.1.10.0/24", "10.1.11.0/24"]
data_subnet_cidrs    = ["10.1.20.0/24", "10.1.21.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]
enable_nat_gateway   = true
