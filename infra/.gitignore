# ── Terraform state files ────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform variable files with secrets ───────────────────
# Use terraform.tfvars.example as a template.
# Never commit real tfvars.
terraform.tfvars
*.auto.tfvars

# ── Terraform init artifacts ─────────────────────────────────
.terraform/
.terraform.lock.hcl

# ── Crash logs ───────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files ────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── CLI config ───────────────────────────────────────────────
.terraformrc
terraform.rc
